# ASN frontend — Base Sepolia. Copy to .env.local for local dev, or set in Vercel.
# After running the one-time /deploy flow, paste the addresses it prints here.

# Optional: a dedicated Base Sepolia RPC (recommended for reliable feed log queries, e.g. Alchemy).
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# Deployed contract addresses (filled in by the /deploy dApp output)
NEXT_PUBLIC_AGENTID=
NEXT_PUBLIC_CAPABILITY_TOKEN=
NEXT_PUBLIC_PUBLICATIONS=
NEXT_PUBLIC_TBA_IMPL=
NEXT_PUBLIC_TBA_KEY_REGISTRY=
NEXT_PUBLIC_PAYMASTER=
